# Copy this file to .env and fill in your values

# ── Database ──
# PostgreSQL connection string
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/resend_clone

# ── AWS ──
# Configure via `aws configure` or set explicitly:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Cloudflare DNS (optional) ──
# Enables auto-configure for domain verification
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ── Dashboard Auth ──
# Master key that unlocks the dashboard and API
# DASHBOARD_KEY=your-secret-key
