{
  "name": "opensend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": ["packages/*"],
  "scripts": {
    "postinstall": "bash scripts/postinstall-star.sh 2>/dev/null || true && node scripts/install-git-hooks.mjs",
    "dev": "next dev --port 3016",
    "build": "next build",
    "build:ingester": "bun build ./packages/ingester/src/server.ts --target bun --outfile ./packages/ingester/dist/server.js",
    "start": "next start",
    "start:ingester": "bun ./packages/ingester/src/server.ts",
    "check": "node scripts/check-changed-files.mjs",
    "check:full": "bun run typecheck && bun run lint",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/client-sesv2": "^3.1019.0",
    "@aws-sdk/client-sqs": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@testing-library/dom": "^10.4.1",
    "better-auth": "^1.6.8",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "lucide-react": "^1.11.0",
    "next": "^16.2.1",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.17.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.4",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
