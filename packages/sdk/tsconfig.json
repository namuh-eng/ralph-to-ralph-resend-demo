{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "strict": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "..",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "node16"
  },
  "include": ["src", "../core/src/dto/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
